{
  "name": "genpark-product-comparison-agent-skill",
  "description": "GenPark multi-product comparison agent skill. Evaluates feature matrices, user priorities, pricing parameters and outputs structured markdown comparisons and product recommendation ratings.",
  "version": "1.0.0",
  "author": "genpark",
  "inputs": {
    "products": {
      "type": "array",
      "description": "List of products to compare.",
      "items": {
        "properties": {
          "sku": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "rating": {
            "type": "number"
          },
          "features": {
            "type": "object"
          }
        },
        "required": [
          "sku",
          "name",
          "price",
          "rating",
          "features"
        ]
      }
    },
    "priorities": {
      "type": "object",
      "description": "User attribute priorities (e.g. price, performance) weighted 1-5.",
      "properties": {
        "price_importance": {
          "type": "integer",
          "default": 3
        },
        "feature_richness": {
          "type": "integer",
          "default": 3
        }
      }
    }
  },
  "outputs": {
    "comparison_table_markdown": {
      "type": "string"
    },
    "ranked_skus": {
      "type": "array",
      "items": {
        "properties": {
          "sku": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "verdict": {
            "type": "string"
          }
        }
      }
    }
  },
  "prompt": "You are a GenPark comparison agent. Build a detailed side-by-side markdown comparison table of the products and score them mathematically based on the user priorities."
}